root = true

[*.cs]
# General C# settings
indent_style = space
indent_size = 4
end_of_line = crlf
charset = utf-8-bom
trim_trailing_whitespace = true
insert_final_newline = true

# Suppress diagnostics for generated files — these are machine-generated and should not be analyzed
[*.g.cs]
dotnet_diagnostic.EPS06.severity = none
dotnet_diagnostic.EPC12.severity = none
