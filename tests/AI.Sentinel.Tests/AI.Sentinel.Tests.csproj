<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>net8.0;net10.0</TargetFrameworks>
    <IsPackable>false</IsPackable>
    <RollForward>LatestMajor</RollForward>
    <!-- In xUnit test projects, ConfigureAwait(false) is forbidden by xUnit1030; suppress MA0004 here -->
    <!-- HLQ005 conflicts with xUnit2013: HLQ005 bans "Single", xUnit2013 requires Assert.Single; suppress HLQ005 in tests -->
    <NoWarn>$(NoWarn);MA0004;HLQ005</NoWarn>
    <EmitCompilerGeneratedFiles>true</EmitCompilerGeneratedFiles>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\src\AI.Sentinel\AI.Sentinel.csproj" />
    <ProjectReference Include="..\..\src\AI.Sentinel.AspNetCore\AI.Sentinel.AspNetCore.csproj" />
    <ProjectReference Include="..\..\src\AI.Sentinel.Cli\AI.Sentinel.Cli.csproj" />
    <ProjectReference Include="..\..\src\AI.Sentinel.ClaudeCode\AI.Sentinel.ClaudeCode.csproj" />
    <ProjectReference Include="..\..\src\AI.Sentinel.ClaudeCode.Cli\AI.Sentinel.ClaudeCode.Cli.csproj" />
    <ProjectReference Include="..\..\src\AI.Sentinel.Copilot\AI.Sentinel.Copilot.csproj" />
    <ProjectReference Include="..\..\src\AI.Sentinel.Copilot.Cli\AI.Sentinel.Copilot.Cli.csproj" />
    <ProjectReference Include="..\..\src\AI.Sentinel.Mcp\AI.Sentinel.Mcp.csproj" />
    <ProjectReference Include="..\..\src\AI.Sentinel.Mcp.Cli\AI.Sentinel.Mcp.Cli.csproj" />
    <PackageReference Include="xunit" Version="2.9.3" />
    <PackageReference Include="xunit.runner.visualstudio" Version="3.1.5" />
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="18.8.1" />
    <PackageReference Include="NSubstitute" Version="6.0.0" />
    <PackageReference Include="ZeroAlloc.Serialisation" Version="2.4.0" />
    <PackageReference Include="ZeroAlloc.Serialisation.SystemTextJson" Version="2.4.*" />
    <PackageReference Include="Microsoft.Extensions.AI.Abstractions" Version="10.8.1" />
    <PackageReference Include="Microsoft.Extensions.AI" Version="10.8.1" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" Version="10.0.10" />
    <PackageReference Include="Microsoft.AspNetCore.TestHost" Version="8.0.29" Condition="'$(TargetFramework)' == 'net8.0'" />
    <PackageReference Include="Microsoft.AspNetCore.TestHost" Version="10.0.10" Condition="'$(TargetFramework)' == 'net10.0'" />
  </ItemGroup>
  <ItemGroup>
    <None Update="Fixtures\**\*.*">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>
</Project>
